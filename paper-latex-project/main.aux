\@writefile{lot}{\contentsline {table}{\numberline {VIII}{\ignorespaces Normalization kernel latency (ms, lower is better) before and after RC0 correction, re-timed on the A100-SXM4 (locked clocks). $E_\text  {lib}$ = library efficiency after fix, relative to PyTorch. \emph  {Before} is the unoptimized TileLang kernel (cf.\ \cref  {tab:norm}); \emph  {After} is the AKO4ALL-optimized kernel. The unoptimized kernels are memory-latency-bound (RC0) and hence clock-invariant, so \emph  {Before} matches the unlocked profile in \cref  {tab:norm} to within noise. Input shape: $8192 \times 8192$.}}{12}{table.8}\protected@file@percent }
\newlabel{tab:mitig:norm}{{VIII}{12}{Normalization kernel latency (ms, lower is better) before and after RC0 correction, re-timed on the A100-SXM4 (locked clocks). $E_\text {lib}$ = library efficiency after fix, relative to PyTorch. \emph {Before} is the unoptimized TileLang kernel (cf.\ \cref {tab:norm}); \emph {After} is the AKO4ALL-optimized kernel. The unoptimized kernels are memory-latency-bound (RC0) and hence clock-invariant, so \emph {Before} matches the unlocked profile in \cref {tab:norm} to within noise. Input shape: $8192 \times 8192$}{table.8}{}}
\newlabel{tab:mitig:norm@cref}{{[table][8][]VIII}{[1][11][]12}}
\@writefile{lot}{\contentsline {table}{\numberline {IX}{\ignorespaces Convolution mitigation across the filter family on the A100-SXM4 (optimized implicit-GEMM Triton, FP16; input $32\times 256\times 128\times 128$). $E_\text  {lib}$ = library efficiency relative to PyTorch/cuDNN; the mitigation holds 36--76\% across the $1\times 1$--$7\times 7$ filter family, all correct.}}{12}{table.9}\protected@file@percent }
\newlabel{tab:mitig:conv}{{IX}{12}{Convolution mitigation across the filter family on the A100-SXM4 (optimized implicit-GEMM Triton, FP16; input $32\times 256\times 128\times 128$). $E_\text {lib}$ = library efficiency relative to PyTorch/cuDNN; the mitigation holds 36--76\% across the $1\times 1$--$7\times 7$ filter family, all correct}{table.9}{}}
\newlabel{tab:mitig:conv@cref}{{[table][9][]IX}{[1][12][]12}}
\@writefile{toc}{\contentsline {paragraph}{\numberline {\mbox  {VII-C}0a}Finding: Restructuring Conv2d as an implicit GEMM with FP16 Tensor Core acceleration, input padding to 16-byte alignment (addressing RC1), and an expanded autotune configuration space (addressing RC2) yields a $2.57\times $ latency reduction ($32.1\nobreakspace  {}\text  {ms} \to 12.5\nobreakspace  {}\text  {ms}$) in the AKO4ALL optimization campaign. On the A100-SXM4, where cuDNN is substantially faster, the same implicit-GEMM restructuring holds 36--76\% of PyTorch/cuDNN efficiency across the $1\times 1$--$7\times 7$ filter family (all correct)--- the gap is narrowed but not closed.}{12}{paragraph.7.3.0.1}\protected@file@percent }
