\citation{zhou2021implicit}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Root-cause summary. Measured contribution is the latency speedup recovered by the corresponding mitigation (\cref  {sec:mitigation}); ``---'' indicates no direct mitigation experiment conducted. RC0a and RC0b are TileLang-specific; RC1--RC4 affect both DSLs.\relax }}{11}{table.caption.30}\protected@file@percent }
\newlabel{tab:rootcauses}{{5}{11}{Root-cause summary. Measured contribution is the latency speedup recovered by the corresponding mitigation (\cref {sec:mitigation}); ``---'' indicates no direct mitigation experiment conducted. RC0a and RC0b are TileLang-specific; RC1--RC4 affect both DSLs.\relax }{table.caption.30}{}}
\newlabel{tab:rootcauses@cref}{{[table][5][]5}{[1][10][]11}}
\@writefile{toc}{\contentsline {paragraph}{Finding: For LayerNorm, two sequential optimizations (each necessary, neither sufficient alone) bring TileLang to within 2\% of PyTorch throughput after 18 iterations: (1) replacing \texttt  {T.serial} reduction loops with the native \texttt  {T.reduce} primitive yields a $208\times $ latency reduction (1090\nonbreakingspace ms $\to $ 5.24\nonbreakingspace ms); (2) switching to native bfloat16 I/O and eliminating intermediate \texttt  {.float()} precision casts yields a $3.4\times $ reduction from the best intermediate result (3.02\nonbreakingspace ms $\to $ 0.89\nonbreakingspace ms). For RMSNorm, both fixes were applied simultaneously in a single iteration ($796\times $, 716\nonbreakingspace ms $\to $ 0.90\nonbreakingspace ms). These results confirm RC0 as the primary cause of TileLang's normalization deficit.}{11}{section*.31}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Normalization kernel latency (ms, lower is better) before and after RC0 correction. $E_\text  {lib}$ = library efficiency after fix, relative to PyTorch. Input shape: $8192 \times 8192$.\relax }}{11}{table.caption.32}\protected@file@percent }
\newlabel{tab:mitig:norm}{{6}{11}{Normalization kernel latency (ms, lower is better) before and after RC0 correction. $E_\text {lib}$ = library efficiency after fix, relative to PyTorch. Input shape: $8192 \times 8192$.\relax }{table.caption.32}{}}
\newlabel{tab:mitig:norm@cref}{{[table][6][]6}{[1][11][]11}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.2}Convolution: Partial Recovery via Implicit GEMM}{11}{subsection.7.2}\protected@file@percent }
\newlabel{sec:mitig:conv}{{7.2}{11}{Convolution: Partial Recovery via Implicit GEMM}{subsection.7.2}{}}
\newlabel{sec:mitig:conv@cref}{{[subsection][2][7]7.2}{[1][11][]11}}
\@writefile{toc}{\contentsline {paragraph}{Finding: Restructuring Conv2d as an implicit GEMM with FP16 Tensor Core acceleration, input padding to 16-byte alignment (addressing RC1), and an expanded autotune configuration space (addressing RC2) yields a $2.57\times $ latency reduction ($32.1\nonbreakingspace \text  {ms} \to 12.5\nonbreakingspace \text  {ms}$). The resulting kernel achieves 80\% of PyTorch/cuDNN efficiency on the tested shape--- the gap is narrowed but not closed.}{11}{section*.33}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Convolution kernel latency (ms, lower is better) before and after RC1+RC2 mitigation. Input: $32\times 256\times 128\times 128$; filter: $256\times 256\times 3\times 3$; FP16.\relax }}{12}{table.caption.34}\protected@file@percent }
\newlabel{tab:mitig:conv}{{7}{12}{Convolution kernel latency (ms, lower is better) before and after RC1+RC2 mitigation. Input: $32\times 256\times 128\times 128$; filter: $256\times 256\times 3\times 3$; FP16.\relax }{table.caption.34}{}}
\newlabel{tab:mitig:conv@cref}{{[table][7][]7}{[1][12][]12}}
