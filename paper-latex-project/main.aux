\newlabel{sec:mitig:norm}{{7.2}{10}{Normalization Kernels: Correcting RC0}{subsection.7.2}{}}
\newlabel{sec:mitig:norm@cref}{{[subsection][2][7]7.2}{[1][10][]10}}
\@writefile{toc}{\contentsline {paragraph}{Finding: Correcting RC0 with two optimizations (each necessary, neither sufficient alone) brings TileLang LayerNorm to $124\%$ and RMSNorm to $990\%$ of PyTorch throughput on the A100-SXM4--- a $1347\times $ and $1157\times $ reduction over the unoptimized TileLang baseline (\cref  {tab:norm}): (1) replacing \texttt  {T.serial} reduction loops with the native \texttt  {T.reduce} primitive (the dominant step; in the RTX 4000 Ada optimization campaign this change alone gave $208\times $); (2) switching to native bfloat16/float16 I/O and eliminating intermediate \texttt  {.float()} precision casts. These results confirm RC0 as the primary cause of TileLang's normalization deficit and as fully correctable in user space.}{10}{section*.40}\protected@file@percent }
\citation{zhou2021implicit}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Root-cause summary. Measured contribution is the latency speedup recovered by the corresponding mitigation (\cref  {sec:mitigation}); ``---'' indicates no direct mitigation experiment conducted. RC0a, RC0b, and RC3 are TileLang-specific; RC1, RC2, and RC4 affect both DSLs. Per-RC counter values are consolidated in the A100 and GH200 \texttt  {ncu\_summary.csv} files, which agree on the RC signatures.\relax }}{11}{table.caption.36}\protected@file@percent }
\newlabel{tab:rootcauses}{{6}{11}{Root-cause summary. Measured contribution is the latency speedup recovered by the corresponding mitigation (\cref {sec:mitigation}); ``---'' indicates no direct mitigation experiment conducted. RC0a, RC0b, and RC3 are TileLang-specific; RC1, RC2, and RC4 affect both DSLs. Per-RC counter values are consolidated in the A100 and GH200 \texttt {ncu\_summary.csv} files, which agree on the RC signatures.\relax }{table.caption.36}{}}
\newlabel{tab:rootcauses@cref}{{[table][6][]6}{[1][10][]11}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Evaluation heuristics on the GH200: optimized-kernel roofline fraction $\rho $ (achieved/hardware peak; \emph  {mem}=HBM bandwidth, \emph  {comp}=FP16 Tensor-Core), PyTorch-relative efficiency $E_\text  {lib}$, and the \emph  {cliff} (naive/optimized speedup). A high recovered $\rho $ marks an \emph  {authoring artifact}; a low $\rho $ that survives optimization marks a \emph  {structural residual}. Source: \texttt  {experiments/results/NVIDIA\_GH200\_480GB/cliff\_roofline.csv}.\relax }}{11}{table.caption.39}\protected@file@percent }
\newlabel{tab:roofline}{{7}{11}{Evaluation heuristics on the GH200: optimized-kernel roofline fraction $\rho $ (achieved/hardware peak; \emph {mem}=HBM bandwidth, \emph {comp}=FP16 Tensor-Core), PyTorch-relative efficiency $E_\text {lib}$, and the \emph {cliff} (naive/optimized speedup). A high recovered $\rho $ marks an \emph {authoring artifact}; a low $\rho $ that survives optimization marks a \emph {structural residual}. Source: \texttt {experiments/results/NVIDIA\_GH200\_480GB/cliff\_roofline.csv}.\relax }{table.caption.39}{}}
\newlabel{tab:roofline@cref}{{[table][7][]7}{[1][10][]11}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Normalization kernel latency (ms, lower is better) before and after RC0 correction, re-timed on the A100-SXM4 (locked clocks). $E_\text  {lib}$ = library efficiency after fix, relative to PyTorch. \emph  {Before} is the unoptimized TileLang kernel (cf.\ \cref  {tab:norm}); \emph  {After} is the AKO4ALL-optimized kernel. The unoptimized kernels are memory-latency-bound (RC0) and hence clock-invariant, so \emph  {Before} matches the unlocked profile in \cref  {tab:norm} to within noise. Input shape: $8192 \times 8192$.\relax }}{11}{table.caption.41}\protected@file@percent }
\newlabel{tab:mitig:norm}{{8}{11}{Normalization kernel latency (ms, lower is better) before and after RC0 correction, re-timed on the A100-SXM4 (locked clocks). $E_\text {lib}$ = library efficiency after fix, relative to PyTorch. \emph {Before} is the unoptimized TileLang kernel (cf.\ \cref {tab:norm}); \emph {After} is the AKO4ALL-optimized kernel. The unoptimized kernels are memory-latency-bound (RC0) and hence clock-invariant, so \emph {Before} matches the unlocked profile in \cref {tab:norm} to within noise. Input shape: $8192 \times 8192$.\relax }{table.caption.41}{}}
\newlabel{tab:mitig:norm@cref}{{[table][8][]8}{[1][11][]11}}
