\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Library efficiency (\%) of Triton and TileLang kernels relative to cuBLAS/cuDNN on the NVIDIA A100-SXM4-40GB, by kernel category (log scale; dashed line = 100\% parity). GEMM shows IQR boxes (whiskers $1.5\times $ IQR); other categories show per-kernel dots ($n=2$). $\diamond $\nobreakspace  {}873.0\% (Triton, Norm.) marks \texttt  {rms\_norm}: unfair-baseline artifact, not a DSL win (\Cref  {tab:summary}). Flier 468.5\% (TileLang, GEMM) marks \texttt  {fused\_linear\_activation}: genuine fusion advantage (\Cref  {sec:eval:gemm}). Attention excluded: Triton's tiled FlashAttention-2\nobreakspace  {}\cite  {dao2023flashattention2} and TileLang's untiled $O(n^2)$ kernel implement algorithmically different computations, so no single library-efficiency number is a valid DSL-versus-library comparison.}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:overview}{{1}{4}{Library efficiency (\%) of Triton and TileLang kernels relative to cuBLAS/cuDNN on the NVIDIA A100-SXM4-40GB, by kernel category (log scale; dashed line = 100\% parity). GEMM shows IQR boxes (whiskers $1.5\times $ IQR); other categories show per-kernel dots ($n=2$). $\diamond $~873.0\% (Triton, Norm.) marks \texttt {rms\_norm}: unfair-baseline artifact, not a DSL win (\Cref {tab:summary}). Flier 468.5\% (TileLang, GEMM) marks \texttt {fused\_linear\_activation}: genuine fusion advantage (\Cref {sec:eval:gemm}). Attention excluded: Triton's tiled FlashAttention-2~\cite {dao2023flashattention2} and TileLang's untiled $O(n^2)$ kernel implement algorithmically different computations, so no single library-efficiency number is a valid DSL-versus-library comparison}{figure.1}{}}
\newlabel{fig:overview@cref}{{[figure][1][]1}{[1][4][]4}}
